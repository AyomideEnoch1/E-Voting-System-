# ── Server ────────────────────────────────────────────────
# Railway sets PORT automatically — do not set this manually on Railway
PORT=5000

# ── Database (Railway MySQL Plugin) ───────────────────────
# Copy these from Railway → your MySQL service → Variables tab
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=evoting

# ── Security ──────────────────────────────────────────────
# Generate a strong random string (min 64 chars) for production
JWT_SECRET=
JWT_EXPIRES=8h
KEY_PASSPHRASE=
ADMIN_SECRET_KEY=

# ── App URLs ──────────────────────────────────────────────
# Set these to your Railway app URL after first deploy
# e.g. https://e-voting-system-production.up.railway.app
APP_URL=
CLIENT_URL=
APP_NAME=RUN E-Voting System

# ── Gmail SMTP ────────────────────────────────────────────
# Your full Gmail address
GMAIL_USER=
# Gmail App Password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=
